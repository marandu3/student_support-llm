# Copy this file to .env and adjust as needed. All values are optional.

# --- Ollama ---
MODEL_NAME=phi3
OLLAMA_URL=http://localhost:11434
REQUEST_TIMEOUT=120

# --- Server ---
HOST=127.0.0.1
PORT=8000
DEBUG=true
# Comma-separated allowlist in production, e.g. https://app.udsm.ac.tz
CORS_ORIGINS=*

# --- Auth (optional) ---
# Registration & login (/auth/register, /auth/login) always work and issue
# signed bearer tokens. Endpoint protection is OFF by default so the local demo
# works without signing in. Turn it on with REQUIRE_AUTH=true (requires a valid
# bearer token or the API key on protected endpoints) and/or set an API_KEY.
REQUIRE_AUTH=false
API_KEY=
API_KEY_HEADER=X-API-Key
# Secret used to sign auth tokens — CHANGE THIS in production.
AUTH_SECRET=udsm-dev-secret-change-me
# Token lifetime in seconds (default 7 days).
AUTH_TOKEN_TTL=604800

# --- Seeded accounts (created on first run) ---
# A demo (student) account so anyone can try the tool, and an admin account
# that can manage the RAG knowledge base. CHANGE the admin password in prod.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin12345
DEMO_USERNAME=demo
DEMO_PASSWORD=demo12345

# --- Database (MongoDB, optional) ---
# When set and reachable, users / chat history / feedback / RAG document
# metadata are stored in MongoDB. Leave empty to use JSON-file + in-memory
# storage (no database needed). docker-compose sets this automatically.
MONGO_URL=
MONGO_DB_NAME=udsm_assistant

# --- Logging ---
LOG_LEVEL=INFO

# --- Uploads / validation ---
MAX_FILE_SIZE=5242880
MAX_QUESTION_LENGTH=1000

# --- RAG / embeddings ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
# auto = use GPU when available, else CPU. Force with "cuda" or "cpu".
EMBEDDING_DEVICE=auto
CHUNK_SIZE=500
CHUNK_OVERLAP=100
TOP_K=3
MIN_RELEVANCE_SCORE=0.15
